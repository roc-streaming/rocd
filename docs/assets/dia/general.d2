direction: right

h1: host 1
h2: host 2
h3: host 3

h1 {
  rocd {
    roc-toolkit
  }
  "your\napp" <-> rocd
}
h2 {
  rocd {
    roc-toolkit
  }
  "your\napp" <-> rocd
}
h3 {
  rocd <-> "your\napp"
  rocd {
    roc-toolkit
  }
}

h1.rocd <-> h2.rocd: conf (ZMQ)
h1.rocd <-> h2.rocd: streams
h2.rocd <-> h3.rocd: conf (ZMQ)
h2.rocd <-> h3.rocd: streams
h3.rocd <-> h1.rocd: conf (ZMQ)
h3.rocd <-> h1.rocd: streams
